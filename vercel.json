{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cinescope-nine-pink.vercel.app" }],
      "destination": "https://bynge.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap.xml" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
